            function setupSimpleSlider(trackId, thumbId, fillId, onComplete) {
                setTimeout(() => {
                    const track = document.getElementById(trackId);
                    const thumb = document.getElementById(thumbId);
                    const fill = document.getElementById(fillId);
                    if (!track || !thumb || !fill) return;
                    let isDragging = false;
                    let thumbLeft = 3;
                    const thumbWidth = 40;
                    const maxLeft = track.clientWidth - thumbWidth - 6;

                    function updatePos(clientX) {
                        const rect = track.getBoundingClientRect();
                        let newLeft = clientX - rect.left - thumbWidth / 2;
                        newLeft = Math.max(3, Math.min(maxLeft, newLeft));
                        thumbLeft = newLeft;
                        thumb.style.left = newLeft + 'px';
                        fill.style.width = ((newLeft - 3) / (maxLeft - 3) * 100 + 4) + '%';
                    }
                    thumb.addEventListener('mousedown', e => { if (!isLevelCompleted(currentLevel)) {
                            isDragging = true;
                            e.preventDefault(); } });
                    document.addEventListener('mousemove', e => { if (isDragging) updatePos(e.clientX); });
                    document.addEventListener('mouseup', () => {
                        if (isDragging && thumbLeft >= maxLeft - 8) onComplete();
                        else if (isDragging) { thumbLeft = 3;
                            thumb.style.left = '3px';
                            fill.style.width = '0%'; }
                        isDragging = false;
                    });
                    thumb.addEventListener('touchstart', e => { if (!isLevelCompleted(currentLevel)) {
                            isDragging = true;
                            e.preventDefault(); } });
                    document.addEventListener('touchmove', e => { if (isDragging) updatePos(e.touches[0]
                            .clientX); });
                    document.addEventListener('touchend', () => {
                        if (isDragging && thumbLeft >= maxLeft - 8) onComplete();
                        else if (isDragging) { thumbLeft = 3;
                            thumb.style.left = '3px';
                            fill.style.width = '0%'; }
                        isDragging = false;
                    });
