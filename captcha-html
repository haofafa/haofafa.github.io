<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>验证码终极挑战 - 10关</title>
    <style>
        :root {
            --bg: #f0f2f5;
            --card-bg: #ffffff;
            --text: #1a1a2e;
            --border: #e2e8f0;
            --accent: #fb7299;
            --success: #10b981;
            --error: #ef4444;
            --shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
            --radius: 14px;
            --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font);
            background: linear-gradient(135deg, #fce4ec 0%, #f5f5f5 50%, #e3f2fd 100%);
            color: var(--text);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            user-select: none;
            -webkit-user-select: none;
        }

        .container {
            width: 100%;
            max-width: 520px;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
        }
        .header h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fb7299;
        }
        .score-display {
            display: inline-block;
            margin-top: 6px;
            background: #fff;
            padding: 6px 18px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
            box-shadow: var(--shadow);
            color: #fb7299;
            border: 1.5px solid #fce4ec;
        }

        .level-selector {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            justify-content: center;
            margin-bottom: 20px;
        }
        .level-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid var(--border);
            background: #fff;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text);
            transition: all 0.18s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .level-btn:hover {
            border-color: #fb7299;
            color: #fb7299;
        }
        .level-btn.active {
            background: #fb7299;
            color: #fff;
            border-color: #fb7299;
        }
        .level-btn.passed {
            background: var(--success);
            color: #fff;
            border-color: var(--success);
        }
        .level-btn.failed {
            background: var(--error);
            color: #fff;
            border-color: var(--error);
        }
        .level-btn.skipped {
            background: #94a3b8;
            color: #fff;
            border-color: #94a3b8;
        }

        .card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 28px 22px;
            text-align: center;
            min-height: 420px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border: 1px solid #fce4ec;
        }

        .level-title {
            font-size: 0.72rem;
            letter-spacing: 2px;
            color: #c0a0b0;
            margin-bottom: 14px;
            font-weight: 600;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 10px 22px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-size: 0.88rem;
            font-weight: 600;
            font-family: var(--font);
        }
        .btn-primary {
            background: #fb7299;
            color: #fff;
        }
        .btn-primary:hover {
            background: #e85d7a;
        }
        .btn-secondary {
            background: #fff;
            color: #888;
            border: 1.5px solid #e8e8e8;
        }
        .btn-danger {
            background: #fff;
            color: #ef4444;
            border: 1.5px solid #fecaca;
        }
        .btn-danger:hover {
            background: #fef2f2;
        }
        .btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            pointer-events: none;
        }

        .feedback {
            margin-top: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            min-height: 22px;
        }
        .feedback.success {
            color: var(--success);
        }
        .feedback.error {
            color: var(--error);
        }
        .feedback.info {
            color: #94a3b8;
        }

        .card-actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .note {
            font-size: 0.7rem;
            color: #c0b0b8;
            margin-top: 10px;
        }

        .captcha-canvas {
            border-radius: 8px;
            border: 2px solid #fce4ec;
            margin: 8px auto;
            display: block;
            max-width: 100%;
        }

        .text-input {
            width: 100%;
            max-width: 260px;
            padding: 10px 14px;
            border-radius: 8px;
            border: 2px solid #f0d0db;
            font-size: 0.9rem;
            font-family: var(--font);
            text-align: center;
            outline: none;
        }
        .text-input:focus {
            border-color: #fb7299;
            box-shadow: 0 0 0 3px rgba(251, 114, 153, 0.1);
        }

        .slider-container {
            width: 280px;
            margin: 8px auto;
        }
        .slider-track {
            width: 100%;
            height: 48px;
            background: #fce4ec;
            border-radius: 24px;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            border: 1.5px solid #f8d0dc;
        }
        .slider-fill {
            height: 100%;
            background: linear-gradient(90deg, #fce4ec, #fb7299);
            border-radius: 24px 0 0 24px;
            width: 0%;
        }
        .slider-thumb {
            position: absolute;
            top: 3px;
            left: 3px;
            width: 40px;
            height: 40px;
            background: #fff;
            border-radius: 50%;
            box-shadow: 0 2px 8px rgba(251, 114, 153, 0.25);
            cursor: grab;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            z-index: 2;
            border: 2px solid #fb7299;
        }
        .slider-thumb:active {
            cursor: grabbing;
        }
        .slider-label {
            position: absolute;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            font-size: 0.78rem;
            color: #c090a0;
            z-index: 1;
        }

        .image-options {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: center;
            margin: 8px 0;
        }
        .image-option {
            width: 90px;
            height: 90px;
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            border: 3px solid #f8e0e8;
            transition: all 0.15s ease;
            position: relative;
        }
        .image-option:hover {
            border-color: #fb7299;
            transform: translateY(-3px);
        }
        .image-option.selected-option {
            border-color: #fb7299 !important;
            box-shadow: 0 0 0 4px rgba(251, 114, 153, 0.3);
        }
        .image-option img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .grid-container {
            display: grid;
            gap: 5px;
            margin: 8px auto;
            justify-content: center;
        }
        .grid-cell-img {
            border-radius: 8px;
            border: 2px solid #f8e0e8;
            cursor: pointer;
            overflow: hidden;
            transition: all 0.15s ease;
            position: relative;
        }
        .grid-cell-img:hover {
            border-color: #fb7299;
        }
        .grid-cell-img.selected-cell {
            border-color: #fb7299 !important;
            box-shadow: 0 0 0 3px rgba(251, 114, 153, 0.35);
        }

        .oneclick-area {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: linear-gradient(135deg, #fce4ec, #fff);
            border: 3px dashed #fb7299;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1rem;
            color: #fb7299;
            font-weight: 600;
            margin: 10px auto;
        }
        .oneclick-area:hover {
            background: #fff5f7;
            transform: scale(1.05);
        }

        .char-btn {
            position: absolute;
            background: transparent;
            border: none;
            cursor: pointer;
            font-weight: bold;
            font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
            text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
            transition: all 0.15s ease;
            z-index: 3;
            padding: 6px 10px;
            min-width: 32px;
            text-align: center;
        }
        .char-btn:hover {
            transform: scale(1.3);
            color: #ffe066 !important;
        }
        .char-btn.correct-click {
            color: #4eff4e !important;
            text-shadow: 0 0 10px rgba(78, 255, 78, 0.8);
        }

        .click-badge {
            position: absolute;
            background: #fb7299;
            color: #fff;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            font-size: 0.7rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
            pointer-events: none;
            animation: badgePop 0.3s ease;
            box-shadow: 0 2px 8px rgba(251, 114, 153, 0.5);
        }
        @keyframes badgePop {
            0% {
                transform: scale(0);
                opacity: 0;
            }
            50% {
                transform: scale(1.3);
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .click-badge-wrong {
            background: #ef4444;
            box-shadow: 0 2px 8px rgba(239, 68, 68, 0.5);
        }

        .puzzle-piece-img {
            position: absolute;
            z-index: 5;
            pointer-events: none;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
            border-radius: 3px;
        }

        .result-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            backdrop-filter: blur(4px);
        }
        .result-card {
            background: #fff;
            border-radius: 20px;
            padding: 36px 28px;
            text-align: center;
            max-width: 400px;
            width: 90%;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
            border: 2px solid #fce4ec;
        }
        .result-score {
            font-size: 4.5rem;
            font-weight: 800;
            letter-spacing: -2px;
            background: linear-gradient(135deg, #fb7299, #ff9db5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .twisted-display {
            display: inline-flex;
            gap: 4px;
            flex-wrap: wrap;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: 700;
            min-height: 28px;
            margin-top: 6px;
            align-items: center;
        }
        .twisted-display img {
            display: inline-block;
            vertical-align: middle;
        }
        .twisted-display .arrow-sep {
            color: #c0b0b8;
            font-size: 0.85rem;
            margin: 0 2px;
            display: inline-flex;
            align-items: center;
        }

        @media (max-width: 420px) {
            .card {
                padding: 20px 12px;
            }
            .slider-container {
                width: 240px;
            }
            .image-option {
                width: 70px;
                height: 70px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🔐 验证码终极挑战</h1>
            <span class="score-display" id="scoreDisplay">🌸 得分: 0 / 100</span>
        </div>

        <div class="level-selector" id="levelSelector">
            <button class="level-btn" data-level="0">0</button>
            <button class="level-btn" data-level="1">1</button>
            <button class="level-btn" data-level="2">2</button>
            <button class="level-btn" data-level="3">3</button>
            <button class="level-btn" data-level="4">4</button>
            <button class="level-btn" data-level="5">5</button>
            <button class="level-btn" data-level="6">6</button>
            <button class="level-btn" data-level="7">7</button>
            <button class="level-btn" data-level="8">8</button>
            <button class="level-btn" data-level="9">9</button>
        </div>

        <div class="card" id="challengeCard">
            <div class="level-title" id="levelTitle">关卡 0</div>
            <div id="challengeContent"></div>
            <div class="feedback" id="feedback"></div>
            <div class="card-actions">
                <button class="btn btn-secondary" id="btnSkip">⏭ 跳过</button>
                <button class="btn btn-danger" id="btnReset" style="display:none;">🔄 重置</button>
                <button class="btn btn-primary" id="btnSubmit">✨ 提交</button>
            </div>
            <p class="note" id="noteText"></p>
        </div>
    </div>

    <script>
        (function() {
            const TOTAL_LEVELS = 10;
            let currentLevel = 0;
            const levelStatus = {};
            const levelScore = {};
            for (let i = 0; i < TOTAL_LEVELS; i++) { levelStatus[i] = 'pending';
                levelScore[i] = 0; }
            let challengeState = {};
            let totalScore = 0;
            const MAX_SCORE = 100;
            const POINTS_PER_LEVEL = Math.floor(MAX_SCORE / TOTAL_LEVELS);

            const levelSelector = document.getElementById('levelSelector');
            const levelTitle = document.getElementById('levelTitle');
            const challengeContent = document.getElementById('challengeContent');
            const feedbackEl = document.getElementById('feedback');
            const btnSkip = document.getElementById('btnSkip');
            const btnReset = document.getElementById('btnReset');
            const btnSubmit = document.getElementById('btnSubmit');
            const noteText = document.getElementById('noteText');
            const scoreDisplay = document.getElementById('scoreDisplay');
            const levelBtns = levelSelector.querySelectorAll('.level-btn');

            function updateScoreDisplay() {
                scoreDisplay.textContent = `🌸 得分: ${totalScore} / ${MAX_SCORE}`;
            }

            function updateLevelButtons() {
                levelBtns.forEach(btn => {
                    const lv = parseInt(btn.dataset.level);
                    btn.classList.remove('active', 'passed', 'failed', 'skipped');
                    if (lv === currentLevel) btn.classList.add('active');
                    if (levelStatus[lv] === 'passed') btn.classList.add('passed');
                    if (levelStatus[lv] === 'failed') btn.classList.add('failed');
                    if (levelStatus[lv] === 'skipped') btn.classList.add('skipped');
                });
            }

            function setFeedback(msg, type) {
                feedbackEl.textContent = msg;
                feedbackEl.className = 'feedback';
                if (type) feedbackEl.classList.add(type);
            }

            function clearFeedback() {
                feedbackEl.textContent = '';
                feedbackEl.className = 'feedback';
            }

            function isLevelCompleted(lv) {
                return ['passed', 'failed', 'skipped'].includes(levelStatus[lv]);
            }

            function autoAdvance() {
                const nextLevel = currentLevel + 1;
                if (nextLevel < TOTAL_LEVELS) {
                    setTimeout(() => switchLevel(nextLevel), 700);
                } else {
                    setTimeout(showFinalResult, 700);
                }
            }

            function submitPass() {
                if (isLevelCompleted(currentLevel)) return;
                levelStatus[currentLevel] = 'passed';
                levelScore[currentLevel] = POINTS_PER_LEVEL;
                totalScore += POINTS_PER_LEVEL;
                updateScoreDisplay();
                updateLevelButtons();
                setFeedback(`🎉 正确！+${POINTS_PER_LEVEL}分，进入下一关...`, 'success');
                disableInteraction();
                btnReset.style.display = 'none';
                autoAdvance();
            }

            function submitFail() {
                if (isLevelCompleted(currentLevel)) return;
                levelStatus[currentLevel] = 'failed';
                levelScore[currentLevel] = 0;
                updateLevelButtons();
                setFeedback('😢 验证失败，0分，进入下一关...', 'error');
                disableInteraction();
                btnReset.style.display = 'none';
                autoAdvance();
            }

            function submitSkip() {
                if (isLevelCompleted(currentLevel)) return;
                levelStatus[currentLevel] = 'skipped';
                levelScore[currentLevel] = 0;
                updateLevelButtons();
                setFeedback('⏭ 已跳过，进入下一关...', 'info');
                disableInteraction();
                btnReset.style.display = 'none';
                autoAdvance();
            }

            function resetLevel() {
                if (isLevelCompleted(currentLevel)) return;
                challengeState = {};
                clearFeedback();
                renderLevel(currentLevel);
                btnSubmit.disabled = false;
                btnSkip.disabled = false;
                btnReset.style.display = 'inline-flex';
            }

            function disableInteraction() {
                const card = document.getElementById('challengeCard');
                const interactiveEls = card.querySelectorAll(
                    'canvas, input, .grid-cell-img, .image-option, .oneclick-area, .slider-thumb, .char-btn, button:not(#btnSkip):not(#btnSubmit):not(#btnReset)'
                    );
                interactiveEls.forEach(el => {
                    el.style.pointerEvents = 'none';
                    el.style.opacity = '0.6';
                });
                btnSubmit.disabled = true;
                btnSkip.disabled = true;
                btnReset.style.display = 'none';
            }

            function showFinalResult() {
                let grade = '';
                if (totalScore >= 90) grade = '🏆 验证大师';
                else if (totalScore >= 70) grade = '👍 表现不错';
                else if (totalScore >= 50) grade = '🤔 还需努力';
                else grade = '😅 再接再厉';

                const passedCount = Object.values(levelStatus).filter(s => s === 'passed').length;
                const failedCount = Object.values(levelStatus).filter(s => s === 'failed').length;
                const skippedCount = Object.values(levelStatus).filter(s => s === 'skipped').length;

                const overlay = document.createElement('div');
                overlay.className = 'result-overlay';
                overlay.innerHTML = `
                    <div class="result-card">
                        <div style="font-size:0.75rem;color:#c0a0b0;letter-spacing:2px;">🏅 最终成绩单</div>
                        <div class="result-score">${totalScore}</div>
                        <div class="result-grade" style="font-size:1.1rem;font-weight:600;color:#666;">${grade}</div>
                        <div style="margin-top:14px;font-size:0.8rem;color:#888;line-height:1.8;">
                            ✅ 通过: ${passedCount} 关<br>
                            ❌ 失败: ${failedCount} 关<br>
                            ⏭ 跳过: ${skippedCount} 关
                        </div>
                        <button class="btn btn-primary" style="margin-top:18px;background:#fb7299;" onclick="location.reload()">🔄 再来一次</button>
                    </div>
                `;
                document.body.appendChild(overlay);
                overlay.addEventListener('click', function(e) {
                    if (e.target === overlay) overlay.remove();
                });
            }

            function switchLevel(level) {
                if (level < 0 || level >= TOTAL_LEVELS) return;
                currentLevel = level;
                challengeState = {};
                clearFeedback();
                renderLevel(currentLevel);
                updateLevelButtons();
                if (isLevelCompleted(currentLevel)) {
                    btnSubmit.disabled = true;
                    btnSkip.disabled = true;
                    btnReset.style.display = 'none';
                } else {
                    btnSubmit.disabled = false;
                    btnSkip.disabled = false;
                    btnReset.style.display = 'inline-flex';
                }
            }

            function drawInterferenceLines(ctx, width, height, count = 8) {
                ctx.save();
                for (let i = 0; i < count; i++) {
                    ctx.strokeStyle =
                        `rgba(${180+Math.random()*75},${140+Math.random()*60},${160+Math.random()*50},0.35)`;
                    ctx.lineWidth = 0.8 + Math.random() * 1.2;
                    ctx.beginPath();
                    const x1 = Math.random() * width;
                    const y1 = Math.random() * height;
                    const x2 = x1 + (Math.random() - 0.5) * width * 0.7;
                    const y2 = y1 + (Math.random() - 0.5) * height * 0.7;
                    ctx.moveTo(x1, y1);
                    ctx.lineTo(x2, y2);
                    ctx.stroke();
                }
                ctx.restore();
            }

            function drawRandomDots(ctx, width, height, count = 30) {
                for (let i = 0; i < count; i++) {
                    const x = Math.random() * width;
                    const y = Math.random() * height;
                    const r = 1 + Math.random() * 4;
                    ctx.beginPath();
                    ctx.arc(x, y, r, 0, Math.PI * 2);
                    ctx.fillStyle =
                        `rgba(${180+Math.random()*75},${100+Math.random()*80},${140+Math.random()*60},${0.3+Math.random()*0.5})`;
                    ctx.fill();
                }
            }

            function generateCaptchaCanvas(text, width, height, bgColor = '#fefcfd', fontSizeMin = 24, fontSizeMax = 42) {
                const canvas = document.createElement('canvas');
                canvas.width = width;
                canvas.height = height;
                const ctx = canvas.getContext('2d');
                ctx.fillStyle = bgColor;
                ctx.fillRect(0, 0, width, height);
                drawRandomDots(ctx, width, height, 22);
                drawInterferenceLines(ctx, width, height, 8);
                const colors = ['#fb7299', '#e74c3c', '#e67e22', '#2ecc71', '#00a1d6', '#9b59b6', '#f39c12',
                '#1abc9c'];
                const chars = text.split('');
                const avgCharWidth = (fontSizeMin + fontSizeMax) / 2 * 0.65;
                const totalWidth = chars.length * avgCharWidth;
                const startX = Math.max(6, (width - totalWidth) / 2);
                const startY = height / 2 + (fontSizeMin + fontSizeMax) / 6;
                let cx = startX;
                chars.forEach((char, i) => {
                    const color = colors[i % colors.length];
                    const rot = -12 + Math.random() * 24;
                    const scaleX = 0.7 + Math.random() * 0.5;
                    const scaleY = 0.7 + Math.random() * 0.5;
                    const charSize = fontSizeMin + Math.random() * (fontSizeMax - fontSizeMin);
                    ctx.save();
                    ctx.translate(cx, startY + (Math.random() - 0.5) * 14);
                    ctx.rotate(rot * Math.PI / 180);
                    ctx.scale(scaleX, scaleY);
                    ctx.font = `bold ${charSize}px "PingFang SC", "Microsoft YaHei", sans-serif`;
                    ctx.fillStyle = color;
                    ctx.shadowColor = 'rgba(0,0,0,0.12)';
                    ctx.shadowBlur = 2;
                    ctx.fillText(char, 0, 0);
                    ctx.shadowBlur = 0;
                    ctx.restore();
                    cx += avgCharWidth * (0.85 + Math.random() * 0.3);
                });
                drawInterferenceLines(ctx, width, height, 5);
                drawRandomDots(ctx, width, height, 14);
                return canvas;
            }

            function generateTwistedCharCanvas(char, size) {
                const canvas = document.createElement('canvas');
                canvas.width = size;
                canvas.height = size;
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, size, size);
                const colors = ['#fb7299', '#e74c3c', '#e67e22', '#2ecc71', '#00a1d6', '#9b59b6'];
                const color = colors[Math.floor(Math.random() * colors.length)];
                const rot = -10 + Math.random() * 20;
                const scaleX = 0.75 + Math.random() * 0.4;
                const scaleY = 0.75 + Math.random() * 0.4;
                const charSize = size * 0.65;
                ctx.save();
                ctx.translate(size / 2, size / 2);
                ctx.rotate(rot * Math.PI / 180);
                ctx.scale(scaleX, scaleY);
                ctx.font = `bold ${charSize}px "PingFang SC", "Microsoft YaHei", sans-serif`;
                ctx.fillStyle = color;
                ctx.shadowColor = 'rgba(0,0,0,0.2)';
                ctx.shadowBlur = 2;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(char, 0, 0);
                ctx.restore();
                return canvas;
            }

