                ctx.fillRect(0, 0, 300, 120);
                drawRandomDots(ctx, 300, 120, 20);
                drawInterferenceLines(ctx, 300, 120, 8);
                const colors = ['#fb7299', '#e74c3c', '#e67e22', '#2ecc71', '#00a1d6', '#9b59b6'];
                const parts = [`${a}币`, '-', `${b}币`, '=', '?'];
                let cx = 16;
                parts.forEach((part, i) => {
                    ctx.save();
                    ctx.translate(cx, 60 + (Math.random() - 0.5) * 12);
                    ctx.rotate((-8 + Math.random() * 16) * Math.PI / 180);
                    ctx.scale(0.78 + Math.random() * 0.3, 0.78 + Math.random() * 0.3);
                    ctx.font = 'bold 22px "PingFang SC", "Microsoft YaHei", sans-serif';
                    ctx.fillStyle = colors[i % colors.length];
                    ctx.shadowColor = 'rgba(0,0,0,0.1)';
                    ctx.shadowBlur = 2;
                    ctx.fillText(part, 0, 0);
                    ctx.restore();
                    cx += part.length * 18 + 10;
                });
                drawInterferenceLines(ctx, 300, 120, 4);
                drawRandomDots(ctx, 300, 120, 10);

                challengeContent.innerHTML = `
                    <img src="${canvas.toDataURL('image/png')}" class="captcha-canvas" style="width:300px;height:120px;">
                    <input type="text" class="text-input" id="input9" placeholder="输入计算结果（可为负数）" maxlength="10" style="margin-top:8px;">
                `;
                challengeState.level9.checkAnswer = () => {
                    const val = document.getElementById('input9')?.value.trim();
                    const cleaned = val.replace(/币/g, '').replace(/\s+/g, '');
                    return cleaned === String(answer);
                };
            }

            // ============ 按钮事件 ============
            btnSubmit.addEventListener('click', () => {
                if (isLevelCompleted(currentLevel)) return;
                const checkFn = challengeState[`level${currentLevel}`]?.checkAnswer;
                if (checkFn && checkFn()) {
                    submitPass();
                } else {
                    submitFail();
                }
            });

            btnSkip.addEventListener('click', () => {
                if (isLevelCompleted(currentLevel)) return;
                submitSkip();
            });

            btnReset.addEventListener('click', () => {
                if (isLevelCompleted(currentLevel)) return;
                resetLevel();
            });

            levelBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    switchLevel(parseInt(btn.dataset.level));
                });
            });

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
                    e.preventDefault();
                    if (!isLevelCompleted(currentLevel)) btnSubmit.click();
                }
            });

            switchLevel(0);
            updateLevelButtons();
            updateScoreDisplay();
        })();
    </script>
</body>
</html>
